olumn":29,"suggestions":"163"},{"ruleId":"148","severity":2,"message":"149","line":1,"column":8,"messageId":"150","endLine":1,"endColumn":13,"suggestions":"164"},{"ruleId":"148","severity":2,"message":"149","line":1,"column":8,"messageId":"150","endLine":1,"endColumn":13,"suggestions":"165"},{"ruleId":"148","severity":2,"message":"149","line":1,"column":8,"messageId":"150","endLine":1,"endColumn":13,"suggestions":"166"},{"ruleId":"148","severity":2,"message":"167","line":265,"column":11,"messageId":"150","endLine":265,"endColumn":15,"suggestions":"168"},{"ruleId":"148","severity":2,"message":"149","line":1,"column":8,"messageId":"150","endLine":1,"endColumn":13,"suggestions":"169"},{"ruleId":"170","severity":2,"message":"171","line":99,"column":36,"endLine":99,"endColumn":49},{"ruleId":"148","severity":2,"message":"172","line":122,"column":9,"messageId":"150","endLine":122,"endColumn":18,"suggestions":"173"},{"ruleId":"174","severity":2,"message":"175","line":237,"column":7,"messageId":"176","endLine":237,"endColumn":13},{"ruleId":"177","severity":2,"message":"178","line":251,"column":7,"messageId":"179","endLine":251,"endColumn":58,"suggestions":"180"},{"ruleId":"177","severity":2,"message":"178","line":252,"column":7,"messageId":"179","endLine":252,"endColumn":56,"suggestions":"181"},{"ruleId":"177","severity":2,"message":"178","line":253,"column":7,"messageId":"179","endLine":253,"endColumn":39,"suggestions":"182"},{"ruleId":"177","severity":2,"message":"178","line":254,"column":7,"messageId":"179","endLine":254,"endColumn":52,"suggestions":"183"},{"ruleId":"177","severity":2,"message":"178","line":255,"column":7,"messageId":"179","endLine":255,"endColumn":64,"suggestions":"184"},{"ruleId":"174","severity":2,"message":"185","line":377,"column":7,"messageId":"176","endLine":377,"endColumn":15},{"ruleId":"174","severity":2,"message":"186","line":386,"column":7,"messageId":"176","endLine":386,"endColumn":12},"react-hooks/refs","Error: Cannot access refs during render\n\nReact refs are values that are not needed for rendering. Refs should only be accessed outside of render, such as in event handlers or effects. Accessing a ref value (the `current` property) during render can cause your component not to update as expected (https://react.dev/reference/react/useRef).\n\n  58 |\n  59 |   const linuxServersRef = useRef(linuxServers);\n> 60 |   linuxServersRef.current = linuxServers;\n     |   ^^^^^^^^^^^^^^^^^^^^^^^ Cannot update ref during render\n  61 |\n  62 |   // Hydrate theme and font-size from localStorage on mount\n  63 |   useEffect(() => {","react-hooks/set-state-in-effect","Error: Calling setState synchronously within an effect can trigger cascading renders\n\nEffects are intended to synchronize state between React and external systems such as manually updating the DOM, state management libraries, or other platform APIs. In general, the body of an effect should do one or both of the following:\n* Update external systems with the latest state from React.\n* Subscribe for updates from some external system, calling setState in a callback function when external state changes.\n\nCalling setState synchronously within an effect body causes cascading renders that can hurt performance, and is not recommended. (https://react.dev/learn/you-might-not-need-an-effect).\n\n  64 |     const savedTheme = localStorage.getItem('monitoring-theme') || 'dark';\n  65 |     const savedFontSize = localStorage.getItem('monitoring-font-size') || 'medium';\n> 66 |     setTheme(savedTheme);\n     |     ^^^^^^^^ Avoid calling setState() directly within an effect\n  67 |     setFontSize(savedFontSize);\n  68 |     setHistoricalData(generateHistoricalMetrics(16));\n  69 |     setLastCheckTime(new Date().toLocaleTimeString());","react-hooks/rules-of-hooks","React Hook \"usePathname\" is called conditionally. React Hooks must be called in the exact same order in every component render. Did you accidentally call a React Hook after an early return?","Error: Cannot access refs during render\n\nReact refs are values that are not needed for rendering. Refs should only be accessed outside of render, such as in event handlers or effects. Accessing a ref value (the `current` property) during render can cause your component not to update as expected (https://react.dev/reference/react/useRef).\n\n  64 |\n  65 |   const linuxServersRef = useRef(linuxServers);\n> 66 |   linuxServersRef.current = linuxServers;\n     |   ^^^^^^^^^^^^^^^^^^^^^^^ Cannot update ref during render\n  67 |\n  68 |   // Selected Server for Detail Modal\n  69 |   const [selectedServer, setSelectedServer] = useState(null);","no-unused-vars","'React' is defined but never used.","unusedVar",["187"],["188"],["189"],"'lastCheckTime' is defined but never used.",["190"],["191"],["192"],"'defaultProps' is assigned a value but never used.",["193"],["194"],["195"],"'Badge' is defined but never used.",["196"],["197"],["198"],["199"],"'rect' is assigned a value but never used.",["200"],["201"],"react-hooks/purity","Error: Cannot call impure function during render\n\n`Math.random` is an impure function. Calling an impure function can produce unstable results that update unpredictably when the component happens to re-render. (https://react.dev/reference/rules/components-and-hooks-must-be-pure#components-and-hooks-must-be-idempotent).\n\n   97 |  */\n   98 | export const Toggle = ({ label, checked, onChange, id }) => {\n>  99 |   const toggleId = id || `toggle-${Math.random().toString(36).substr(2, 9)}`;\n      |                                    ^^^^^^^^^^^^^ Cannot call impure function\n  100 |   return (\n  101 |     <div className=\"customizer-option\">\n  102 |       <span>{label}</span>","'isNeutral' is assigned a value but never used.",["202"],"no-useless-assignment","The value assigned to 'output' is not used in subsequent statements.","unnecessaryAssignment","no-case-declarations","Unexpected lexical declaration in case block.","unexpected",["203"],["204"],["205"],["206"],["207"],"The value assigned to 'services' is not used in subsequent statements.","The value assigned to 'level' is not used in subsequent statements.",{"messageId":"208","data":"209","fix":"210","desc":"211"},{"messageId":"208","data":"212","fix":"213","desc":"211"},{"messageId":"208","data":"214","fix":"215","desc":"211"},{"messageId":"208","data":"216","fix":"217","desc":"218"},{"messageId":"208","data":"219","fix":"220","desc":"211"},{"messageId":"208","data":"221","fix":"222","desc":"211"},{"messageId":"208","data":"223","fix":"224","desc":"225"},{"messageId":"208","data":"226","fix":"227","desc":"211"},{"messageId":"208","data":"228","fix":"229","desc":"211"},{"messageId":"208","data":"230","fix":"231","desc":"232"},{"messageId":"208","data":"233","fix":"234","desc":"211"},{"messageId":"208","data":"235","fix":"236","desc":"211"},{"messageId":"208","data":"237","fix":"238","desc":"211"},{"messageId":"208","data":"239","fix":"240","desc":"241"},{"messageId":"208","data":"242","fix":"243","desc":"211"},{"messageId":"208","data":"244","fix":"245","desc":"246"},{"messageId":"247","fix":"248","desc":"249"},{"messageId":"247","fix":"250","desc":"249"},{"messageId":"247","fix":"251","desc":"249"},{"messageId":"247","fix":"252","desc":"249"},{"messageId":"247","fix":"253","desc":"249"},"removeVar",{"varName":"254"},{"range":"255","text":"256"},"Remove unused variable 'React'.",{"varName":"254"},{"range":"257","text":"256"},{"varName":"254"},{"range":"258","text":"256"},{"varName":"259"},{"range":"260","text":"256"},"Remove unused variable 'lastCheckTime'.",{"varName":"254"},{"range":"261","text":"256"},{"varName":"254"},{"range":"262","text":"256"},{"varName":"263"},{"range":"264","text":"256"},"Remove unused variable 'defaultProps'.",{"varName":"254"},{"range":"265","text":"256"},{"varName":"254"},{"range":"266","text":"256"},{"varName":"267"},{"range":"268","text":"256"},"Remove unused variable 'Badge'.",{"varName":"254"},{"range":"269","text":"256"},{"varName":"254"},{"range":"270","text":"256"},{"varName":"254"},{"range":"271","text":"256"},{"varName":"272"},{"range":"273","text":"256"},"Remove unused variable 'rect'.",{"varName":"254"},{"range":"274","text":"256"},{"varName":"275"},{"range":"276","text":"256"},"Remove unused variable 'isNeutral'.","addBrackets",{"range":"277","text":"278"},"Add {} brackets around the case block.",{"range":"279","text":"278"},{"range":"280","text":"278"},{"range":"281","text":"278"},{"range":"282","text":"278"},"React",[7,18],"",[7,18],[7,18],"lastCheckTime",[460,477],[7,18],[7,18],"defaultProps",[56,134],[7,18],[7,18],"Badge",[48,55],[7,18],[7,18],[7,18],"rect",[8492,8550],[7,18],"isNeutral",[3014,3061],[9382,9927],"{ const totalMB = Math.round(server.ramTotal * 1024);\n      const usedMB = Math.round(server.ramUsed * 1024);\n      const freeMB = totalMB - usedMB;\n      const buffCache = Math.round(totalMB * 0.15); // mock cache\n      const availableMB = freeMB + Math.round(buffCache * 0.8);\n      output = `              total        used        free      shared  buff/cache   available\nMem:           ${totalMB}        ${usedMB}        ${freeMB}          12        ${buffCache}       ${availableMB}\nSwap:           4096         512        3584`;\n      break; }",[9382,9927],[9382,9927],[9382,9927],[9382,9927]]